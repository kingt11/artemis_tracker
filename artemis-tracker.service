[Unit]
Description=Artemis II Discord Tracker
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/artemis-tracker/src
ExecStart=/opt/artemis-tracker/venv/bin/python -u main.py
Restart=always
RestartSec=10
EnvironmentFile=/opt/artemis-tracker/.env
Environment=PYTHONUNBUFFERED=1

# Update Workflow:
# 1. cd /opt/artemis-tracker
# 2. git pull
# 3. sudo systemctl restart artemis-tracker

[Install]
WantedBy=multi-user.target
